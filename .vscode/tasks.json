{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Claude Code",
      "type": "shell",
      "command": "claude",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Dev: Start All",
      "type": "shell",
      "command": "npm run dev",
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "dev"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Dev: API Only",
      "type": "shell",
      "command": "npx turbo dev --filter=@finsight/api",
