{
  "name": "finsight",
  "private": true,
  "author": "Pratik",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pratikk70/FinSight-Finance-Tracker.git"
  },
  "bugs": {
    "url": "https://github.com/pratikk70/FinSight-Finance-Tracker/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "db:seed": "npm run seed --workspace=apps/api",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0"
}
